{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|mcp__.*read.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{ .chezmoi.homeDir }}/.claude/hooks/log-knowledge-fetch.sh",
            "statusMessage": "Logging knowledge fetch"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/enforce-run-commands.sh"
          }
        ]
      }
    ]
  }
}
